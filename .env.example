# ─── Server ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # set to "production" on live servers

# ─── MongoDB ──────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/cashstore

# ─── Authentication ───────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
ADMIN_API_KEY=replace_with_another_long_random_key_for_api_key_auth

# ─── Stripe ───────────────────────────────────────────────────────
# Live key starts with sk_live_  |  Test key starts with sk_test_
STRIPE_SECRET_KEY=sk_test_...

# ─── PayPal ───────────────────────────────────────────────────────
# Sandbox credentials from developer.paypal.com/apps
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
